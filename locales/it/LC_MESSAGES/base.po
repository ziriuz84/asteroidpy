#: asteroidpy/interface/_config_menus.py:61
msgid ""
"Choose an option\n"
"    1 - Change coordinates\n"
"    2 - Change altitude\n"
"    3 - Change the name of the observer\n"
"    4 - Change the name of the observatory\n"
"    5 - Change the MPC code\n"
"    6 - Change Virtual Horizon\n"
"    0 - Back to configuration menu"
msgstr ""
"Scegli un'opzione\n"
"    1 - Modifica coordinate\n"
"    2 - Modifica altitudine\n"
"    3 - Modifica il nome dell'osservatore\n"
"    4 - Modifica il nome dell'osservatorio\n"
"    5 - Modifica il codice MPC\n"
"    6 - Modifica l'Orizzonte Virtuale\n"
"    0 - Torna al menu di configurazione"

