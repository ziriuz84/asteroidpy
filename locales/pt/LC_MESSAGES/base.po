#: asteroidpy/interface/_config_menus.py:61
msgid ""
"Choose an option\n"
"    1 - Change coordinates\n"
"    2 - Change altitude\n"
"    3 - Change the name of the observer\n"
"    4 - Change the name of the observatory\n"
"    5 - Change the MPC code\n"
"    6 - Change Virtual Horizon\n"
"    0 - Back to configuration menu"
msgstr ""
"Escolha uma opção\n"
"    1 - Alterar coordenadas\n"
"    2 - Alterar altitude\n"
"    3 - Alterar o nome do observador\n"
"    4 - Alterar o nome do observatório\n"
"    5 - Alterar o código MPC\n"
"    6 - Alterar o Horizonte Virtual\n"
"    0 - Voltar ao menu de configuração"

