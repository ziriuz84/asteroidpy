#: asteroidpy/interface/_config_menus.py:61
msgid ""
"Choose an option\n"
"    1 - Change coordinates\n"
"    2 - Change altitude\n"
"    3 - Change the name of the observer\n"
"    4 - Change the name of the observatory\n"
"    5 - Change the MPC code\n"
"    6 - Change Virtual Horizon\n"
"    0 - Back to configuration menu"
msgstr ""
"Elige una opción\n"
"    1 - Cambiar coordenadas\n"
"    2 - Cambiar altitud\n"
"    3 - Cambiar el nombre del observador\n"
"    4 - Cambiar el nombre del observatorio\n"
"    5 - Cambiar el código MPC\n"
"    6 - Cambiar el Horizonte Virtual\n"
"    0 - Volver al menú de configuración"

